# =============================================================================
# LuxeGen — the AI now runs INSIDE the Next.js app (frontend/app/api/*).
# There is no separate server to deploy. Copy this to `frontend/.env.local`.
# Never commit real secrets.
# =============================================================================

# --- Next.js app (frontend/.env.local, and Vercel env vars) -----------------
# REQUIRED: Google Gemini API key. Used server-side only by the API routes.
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional model override (defaults to gemini-1.5-flash):
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_MODEL_NAME=

# --- Vercel deploy -----------------------------------------------------------
# Set Project → Settings → Root Directory = frontend
# Add GEMINI_API_KEY in Project → Settings → Environment Variables, then redeploy.
# BACKEND_URL is NO LONGER required — the old Express backend is embedded now.

# --- Legacy (optional, only if you still run the standalone Express backend) --
# The backend/ folder is kept for reference; it is not needed for deployment.
# BACKEND_URL=http://127.0.0.1:8080
